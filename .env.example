# Copy to .env and fill in real values. .env is git-ignored — never commit it.

# --- PostGIS database container ---
# POSTGRES_DB must match the database name you restore the dump into.
POSTGRES_DB=rmms
POSTGRES_USER=rmms_user
POSTGRES_PASSWORD=change_me_to_a_strong_password

# --- KLRAMS bootstrap super-admin (seeds the first account on startup) ---
ADMIN_PASSWORD=change_me_admin_password
